# Copy to .env and fill in. Defaults run fully offline with the echo provider.
DATABASE_URL=sqlite+aiosqlite:///./chatting_bot.db
JWT_SECRET=change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM: leave as "echo" to run offline; set "openai" + a key for real answers.
LLM_PROVIDER=echo
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
MAX_CONTEXT_TOKENS=4000
